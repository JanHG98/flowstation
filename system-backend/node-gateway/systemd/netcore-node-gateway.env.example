# TBS ingress credential. Configure the same value as auth_token/token in each
# TBS [control_room] section that points to the Node Gateway.
NETCORE_NODE_GATEWAY_NODE_TOKEN=replace-with-long-random-node-token

# WebUI/API roles. Use different random values.
NETCORE_NODE_GATEWAY_VIEWER_TOKEN=replace-with-viewer-token
NETCORE_NODE_GATEWAY_OPERATOR_TOKEN=replace-with-operator-token
NETCORE_NODE_GATEWAY_ADMIN_TOKEN=replace-with-admin-token

# Credential used by the gateway when bridging each node session to the current
# Control Room. This must match the Control Room node token.
NETCORE_NODE_GATEWAY_UPSTREAM_TOKEN=replace-with-control-room-node-token

RUST_LOG=info,netcore_node_gateway=debug
