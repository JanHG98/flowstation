# NetCore Control Room secret environment file.
# Install as: /etc/netcore-control-room/control-room.env
# Permissions: root:root 0600

# Machine token for TBS /node WebSocket.
# This remains in the TBS config.toml [control_room] token = "...".
NETCORE_CONTROL_ROOM_NODE_TOKEN=change-me-node-token

# Bootstrap admin login for first setup/recovery.
# This is NOT used by the TBS and not stored in Windows operator.toml.
NETCORE_CONTROL_ROOM_BOOTSTRAP_USER=jan
NETCORE_CONTROL_ROOM_BOOTSTRAP_PASSWORD=change-me-admin-password
