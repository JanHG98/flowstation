# NetCore Control Room secret environment file.
# Install as: /etc/netcore-control-room/control-room.env
# Permissions: root:root 0600

# Generate examples:
#   openssl rand -hex 32

# Bootstrap token for TBS /node WebSocket.
NETCORE_CONTROL_ROOM_NODE_TOKEN=change-me-node-token

# Bootstrap admin token for operator/API.
# Use this to create named RBAC tokens, then use those named tokens for normal clients.
NETCORE_CONTROL_ROOM_OPERATOR_TOKEN=change-me-operator-token
