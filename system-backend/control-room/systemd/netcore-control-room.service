[Unit]
Description=NetCore Control Room
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=netcore
Group=netcore
ExecStart=/usr/local/bin/netcore-control-room --config /etc/netcore-control-room/control-room.toml --no-auth
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/netcore-control-room

[Install]
WantedBy=multi-user.target
