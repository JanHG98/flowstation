[Unit]
Description=NetCore Call Control
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=netcore
Group=netcore
ExecStart=/usr/local/bin/netcore-call-control --config /etc/netcore/call-control.toml
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/netcore-call-control
Environment=RUST_LOG=netcore_call_control=info

[Install]
WantedBy=multi-user.target
