    {"type":"stat","title":"Firing Alerts","gridPos":{"h":6,"w":6,"x":12,"y":0},"targets":[{"expr":"netcore_observability_alerts_firing","legendFormat":"firing"}]},
    {"type":"timeseries","title":"Target Response Time","gridPos":{"h":9,"w":24,"x":0,"y":6},"targets":[{"expr":"netcore_observability_target_response_ms","legendFormat":"{{service}} / {{target_id}}"}]}
