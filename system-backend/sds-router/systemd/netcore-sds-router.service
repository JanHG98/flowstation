[Unit]
Description=NetCore SDS Router (OPEN LAB)
After=network-online.target netcore-node-gateway.service
Wants=network-online.target

[Service]
Type=simple
User=netcore
Group=netcore
ExecStart=/usr/local/bin/netcore-sds-router --config /etc/netcore/sds-router.toml
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/netcore-sds-router
Environment=RUST_LOG=netcore_sds_router=info

[Install]
WantedBy=multi-user.target
