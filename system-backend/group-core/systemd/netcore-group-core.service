[Unit]
Description=NetCore Group Core
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=netcore
Group=netcore
ExecStart=/usr/local/bin/netcore-group-core --config /etc/netcore/group-core.toml
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/netcore-group-core
Environment=RUST_LOG=netcore_group_core=info

[Install]
WantedBy=multi-user.target
