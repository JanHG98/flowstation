{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:netcore:schema:envelope:v1",
  "title": "NetCore v1 Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "payload_type", "payload"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message_id", "api_version", "kind", "source", "created_at", "delivery"],
      "properties": {
        "message_id": {"type": "string", "format": "uuid"},
        "api_version": {"type": "string", "pattern": "^netcore\\.v[0-9]+(?:\\.[0-9]+)?$"},
        "kind": {"enum": ["command", "event", "query", "reply", "snapshot"]},
        "source": {"type": "string", "minLength": 1, "maxLength": 128},
        "destination": {"type": "string", "minLength": 1, "maxLength": 128},
        "created_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "causation_id": {"type": "string", "format": "uuid"},
        "trace": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "trace_id": {"type": "string", "maxLength": 64},
            "span_id": {"type": "string", "maxLength": 32}
          }
        },
        "delivery": {"enum": ["at_most_once", "at_least_once", "idempotent_at_least_once"]},
        "idempotency_key": {"type": ["string", "null"], "maxLength": 256}
      }
    },
    "payload_type": {"type": "string", "pattern": "^[a-z0-9_.-]+$", "maxLength": 160},
    "payload": true
  }
}
